{
  "name": "telecashapp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "tsx watch --clear-screen=false apps/server/src/index.ts",
    "dev:web": "npm run dev -w @telecash/miniapp",
    "build:web": "npm run build -w @telecash/miniapp",
    "build": "npm run db:generate && npm run build:web",
    "start": "tsx apps/server/src/index.ts",
    "db:deploy": "prisma migrate deploy --schema packages/db/prisma/schema.prisma",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:studio": "prisma studio --schema packages/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prisma": "^6.19.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}

# Telegram bot token (lấy từ @BotFather)
BOT_TOKEN=your-telegram-bot-token

# SQLite — đường dẫn tương đối tới schema.prisma (Prisma tự resolve)
DATABASE_URL="file:./dev.db"

# Cổng HTTP cho API (dùng từ P3)
PORT=3000

# URL Mini App (điền khi tới P3, vd URL Cloudflare Tunnel hoặc Cloudflare Pages)
WEBAPP_URL=https://learn-acting-investments-printable.trycloudflare.com
